@model IEnumerable<HowToMakeCodeFirst.Models.Musteri>

<div class="container mt-4">
    <h2>Müşteri Listesi</h2>
    <hr />
    
    <a asp-action="Create" class="btn btn-primary mb-3">Yeni Müşteri Ekle</a>

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Ad</th>
                <th>Soyad</th>
                <th>TC No</th>
                <th>Telefon</th>
                <th>Kayıt Tarihi</th>
                <th>İşlemler</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var musteri in Model)
            {
                <tr>
                    <td>@musteri.MusteriId</td>
                    <td>@musteri.MusteriAd</td>
                    <td>@musteri.MusteriSoyad</td>
                    <td>@musteri.MusteriTcNo</td>
                    <td>@musteri.MusteriTelNo</td>
                    <td>@musteri.MusteriKayıtTarihi.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@musteri.MusteriId" class="btn btn-warning btn-sm">Güncelle</a>
						<form asp-action="Delete" asp-route-id="@musteri.MusteriId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                        </form>
                        
                    </td>

                </tr>
            }
        </tbody>
    </table>
</div>
